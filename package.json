{
  "name": "a8a",
  "version": "1.0.0",
  "description": "Eastar Jet API Workflow Automation Tool",
  "main": "./out/main/index.js",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "version:stamp": "node scripts/stamp-version.cjs",
    "prepare:mac-icon": "bash scripts/prepare-mac-icon.sh",
    "release:manual": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-release.ps1",
    "build:win": "npm run build && electron-builder --config electron-builder.config.cjs --win",
    "build:mac": "npm run build && npm run prepare:mac-icon && electron-builder --config electron-builder.config.cjs --mac",
    "build:mac:x64": "npm run build && npm run prepare:mac-icon && electron-builder --config electron-builder.config.cjs --mac dmg zip --x64",
    "build:mac:arm64": "npm run build && npm run prepare:mac-icon && electron-builder --config electron-builder.config.cjs --mac dmg zip --arm64",
    "build:linux": "npm run build && electron-builder --config electron-builder.config.cjs --linux"
  },
  "keywords": [
    "electron",
    "api",
    "workflow"
  ],
  "author": "Eastar Jet",
  "license": "SEE LICENSE IN LICENSE.md",
  "main_process": "src/main/index.ts",
  "build": {
    "appId": "com.eastarjet.a8a",
    "productName": "a8a",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "package.json",
      "node_modules/sql.js/**"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "a8a"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "monaco-editor": "^0.52.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^7.3.3"
  }
}
